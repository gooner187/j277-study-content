  "Binary search": {
    "title": "Binary Search",
    "badge": "J277 2.1 Algorithms",
    "code": [
      "numbers = [2, 4, 6, 8]",
      "target = 6",
      "low = 0",
      "high = 3",
      "found = False",
      "while low <= high AND found == False:",
      "    mid = (low + high) // 2",
      "    if numbers[mid] == target:",
      "        print(\"Found at index\", mid)",
