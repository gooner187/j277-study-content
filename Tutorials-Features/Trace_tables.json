  "Insertion sort": {
    "title": "Insertion Sort",
    "badge": "J277 2.1 Algorithms",
    "code": [
      "numbers = [3, 1, 2]",
      "passCount = 0",
      "for i = 1 to 2:",
      "    passCount = passCount + 1",
      "    key = numbers[i]",
      "    j = i - 1",
      "    while j >= 0 and numbers[j] > key:",
      "        numbers[j+1] = numbers[j]",
      "        j = j - 1",
      "    numbers[j+1] = key",
      "print(numbers)",
      "print(\"passes =\", passCount)"
    ],
