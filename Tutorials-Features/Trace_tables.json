  "Bubble sort": {
    "title": "Bubble Sort",
    "badge": "J277 2.1 Algorithms",
    "code": [
      "nums = [3, 1, 2]",
      "passCount = 0",
      "for pass = 1 to 2:",
      "    passCount = passCount + 1",
      "    for i = 0 to 1-pass:",
      "        if nums[i] > nums[i+1]:",
      "            swap(nums[i], nums[i+1])",
      "print(nums)",
      "print(\"passes =\", passCount)"
    ],
    "cols": [
      "line",
      "pass",
      "passCount",
      "i",
      "nums[i] > nums[i+1]",
      "nums",
      "OUTPUT"
    ],
    "steps": [
